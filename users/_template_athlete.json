    {"data_key": "workout_minutes",             "label": "Workout Time", "emoji": "🏋️", "unit": " min", "target_ref": "daily_targets.workout_minutes","higher_is_better": true,  "decimals": 0},
    {"data_key": "total_cardio_mi",             "label": "Cardio",       "emoji": "🎽", "unit": " mi",  "target_ref": "daily_targets.cardio_mi",      "higher_is_better": true,  "decimals": 2},
    {"data_key": "walking_running_distance_mi", "label": "Walk / Run",   "emoji": "🏃", "unit": " mi",  "higher_is_better": true,  "decimals": 2},
    {"data_key": "cycling_distance_mi",         "label": "Cycling",      "emoji": "🚴", "unit": " mi",  "higher_is_better": true,  "decimals": 2},
    {"data_key": "swimming_distance_mi",        "label": "Swimming",     "emoji": "🏊", "unit": " mi",  "higher_is_better": true,  "decimals": 2},
    {"data_key": "steps",                       "label": "Steps",        "emoji": "👟", "unit": "",     "target_ref": "daily_targets.steps",         "higher_is_better": true,  "decimals": 0}
