  "streaks": [
    {"metric": "protein_g",   "label": "Protein", "unit": "g",    "target_ref": "daily_targets.protein_g",   "higher_is_better": true},
    {"metric": "sleep_hours", "label": "Sleep",   "unit": " hrs", "target_ref": "daily_targets.sleep_hours", "higher_is_better": true},
    {"metric": "steps",       "label": "Steps",   "unit": "",     "target_ref": "daily_targets.steps",       "higher_is_better": true}
  ]
